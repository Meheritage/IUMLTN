    <script type="text/javascript">
        $(function () {
            $('[id*=grd_PDFList]').footable();
            $('[id*=grd_PDFList] tr :last').closest('table').closest('tr').find('td').show();
            $(window).resize(function () {
                location.reload();
            });
            $('[id*=grd_PDFList] tr :last').closest('table').closest('tr').on('click', function () {
                $(this).next('tr').hide();
            });
        });
    </script>
    <script type="text/javascript" language="javascript">
        $(document).ready(function () {

            $('#grd_PDFList').footable({
                breakpoints: {
                    phone: 480,
                    tablet: 1024
                }
            });

            $('#grd_PDFList').data('limit-navigation', 10);
            $('#grd_PDFList').trigger('footable_initialized');

            $('#changepPageSize_grd_PDFList').change(function (e) {
                e.preventDefault();
                var pageSize = $(this).val();
                $('#grd_PDFList').data('page-size', pageSize);
                $('#grd_PDFList').trigger('footable_initialized');
            });

            $('#clearFilter_grd_PDFList').click(function (e) {
                e.preventDefault();
                $('#grd_PDFList').trigger('footable_clear_filter');
            });

        });


    </script>

